<search class="app-search-form" id="app-hearing-search">
  <form>
    {{ govukInput({
      id: "hearingSearch[keywords]",
      name: "hearingSearch[keywords]",
      label: {
        text: "Search by URN, defendant name or operation name",
        classes: "govuk-label--s app-search-form__label"
      },
      value: data.hearingSearch.keywords
    }) }}

    {{ govukButton({
      text: "Search",
      classes: "app-search-form__button"
    }) }}
  </form>

  {% if data.hearingSearch.keywords %}
    <p class="govuk-!-margin-top-2 govuk-!-margin-bottom-0"><a class="govuk-link--no-visited-state" href="/hearings/clear-search">Clear search</a></p>
  {% endif %}
</search>
