<div class="app-sort">
  <p class="govuk-!-font-size-1">
    <b class="govuk-!-margin-right-1">Sort by:</b>
    {% if data.caseSort == 'Status' or not data.caseSort %}
      <span>Status</span>
    {% else %}
      <a href="?caseSort=Status">Status</a>
    {% endif %}
    <span class="govuk-!-margin-left-1 govuk-!-margin-right-1">|</span>
    {% if data.caseSort == 'Hearing date' %}
      <span>Hearing date</span>
    {% else %}
      <a href="?caseSort=Hearing date">Hearing date</a>
    {% endif %}
    <span class="govuk-!-margin-left-1 govuk-!-margin-right-1">|</span>
    {% if data.caseSort == 'PACE clock' %}
      <span>PACE clock</span>
    {% else %}
      <a href="?caseSort=PACE clock">PACE clock</a>
    {% endif %}
    <span class="govuk-!-margin-left-1 govuk-!-margin-right-1">|</span>
    {% if data.caseSort == 'Custody time limit' %}
      <span>CTL</span>
    {% else %}
      <a href="?caseSort=Custody time limit">CTL</a>
    {% endif %}
    <span class="govuk-!-margin-left-1 govuk-!-margin-right-1">|</span>
    {% if data.caseSort == 'Statutory time limit' %}
      <span>STL</span>
    {% else %}
      <a href="?caseSort=Statutory time limit">STL</a>
    {% endif %}
  </p>
</div>
