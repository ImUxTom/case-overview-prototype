<aside class="app-annotation-sidebar" id="annotation-sidebar" aria-label="Annotations">
  <div class="app-annotation-sidebar__inner js-sidebar-inner">
    <div
      class="app-annotation-sidebar__new js-new-annotation-card js-new-annotation-card--evidence"
      hidden
    >
      <div class="app-annotation-form app-annotation-card--blue">
        <p class="app-annotation-card__tag app-annotation-card__tag--blue govuk-!-margin-bottom-0">Evidence</p>
        <div class="app-annotation-form__body">
          {% if hasElements %}
            {% for offence in offences %}
              {% if offence.elementCheckboxItems.length %}
                {{
                  govukCheckboxes({
                    name: "elementsCheckbox",
                    idPrefix: "element-charge-" + offence.charge.id,
                    fieldset: {
                      legend: {
                        text: offence.charge.description,
                        isPageHeading: false,
                        classes: "govuk-fieldset__legend--s"
                      }
                    },
                    classes: "govuk-checkboxes--small js-annotation-element-checkboxes",
                    items: offence.elementCheckboxItems
                  })
                }}
              {% endif %}
            {% endfor %}
          {% else %}
            {{
              govukTextarea({
                label: {
                  text: "Evidence note",
                  classes: "govuk-label--s"
                },
                classes: "govuk-!-margin-bottom-0 js-annotation-note-input",
                rows: 3
              })
            }}
          {% endif %}

          <div class="govuk-button-group govuk-!-margin-bottom-0">
            {{
              govukButton({
                text: "Save",
                classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-annotation",
                attributes: { type: "button" }
              })
            }}
            <a href="#" class="govuk-link js-cancel-annotation">Cancel</a>
          </div>
        </div>
      </div>
    </div>

    <div
      class="app-annotation-sidebar__new js-new-annotation-card js-new-annotation-card--disclosure"
      hidden
    >
      <div class="app-annotation-form app-annotation-card--purple">
        <p class="app-annotation-card__tag app-annotation-card__tag--purple govuk-!-margin-bottom-0">Disclosure</p>
        <div class="app-annotation-form__body">
          {% if hasElements %}
            {% for offence in offences %}
              {% if offence.disclosureElementCheckboxItems.length %}
                {{
                  govukCheckboxes({
                    name: "elementsCheckbox",
                    idPrefix: "disclosure-element-charge-" + offence.charge.id,
                    fieldset: {
                      legend: {
                        text: offence.charge.description,
                        isPageHeading: false,
                        classes: "govuk-fieldset__legend--s"
                      }
                    },
                    classes: "govuk-checkboxes--small js-annotation-element-checkboxes",
                    items: offence.disclosureElementCheckboxItems
                  })
                }}
              {% endif %}
            {% endfor %}
          {% else %}
            {{
              govukTextarea({
                label: {
                  text: "Disclosure note",
                  classes: "govuk-label--s"
                },
                classes: "govuk-!-margin-bottom-0 js-annotation-note-input",
                rows: 3
              })
            }}
          {% endif %}

          <div class="govuk-button-group govuk-!-margin-bottom-0">
            {{
              govukButton({
                text: "Save",
                classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-annotation",
                attributes: { type: "button" }
              })
            }}
            <a href="#" class="govuk-link js-cancel-annotation">Cancel</a>
          </div>
        </div>
      </div>
    </div>

    <div
      class="app-annotation-sidebar__new js-new-annotation-card js-new-annotation-card--information-request"
      hidden
    >
      <div class="app-annotation-form">
        <div class="app-annotation-form__body">
          {{
            govukTextarea({
              label: {
                text: "Information request note",
                classes: "govuk-label--s"
              },
              classes: "govuk-!-margin-bottom-0 js-annotation-note-input",
              rows: 3
            })
          }}

          <div class="govuk-button-group govuk-!-margin-bottom-0">
            {{
              govukButton({
                text: "Save",
                classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-annotation",
                attributes: { type: "button" }
              })
            }}
            <a href="#" class="govuk-link js-cancel-annotation">Cancel</a>
          </div>
        </div>
      </div>
    </div>

    <div
      class="app-annotation-sidebar__new js-new-annotation-card js-new-annotation-card--note"
      hidden
    >
      <div class="app-annotation-form">
        <div class="app-annotation-form__body">
          {{
            govukTextarea({
              label: {
                text: "Note",
                classes: "govuk-label--s"
              },
              classes: "govuk-!-margin-bottom-0 js-annotation-note-input",
              rows: 3
            })
          }}

          <div class="govuk-button-group govuk-!-margin-bottom-0">
            {{
              govukButton({
                text: "Save",
                classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-annotation",
                attributes: { type: "button" }
              })
            }}
            <a href="#" class="govuk-link js-cancel-annotation">Cancel</a>
          </div>
        </div>
      </div>
    </div>

    {% for annotation in annotations %}
      {% set typeLabel = 'Evidence' if annotation.type == 'evidence' else ('Disclosure' if annotation.type == 'disclosure' else ('Note' if annotation.type == 'note' else 'Information request')) %}
      {% set tagColour = 'blue' if annotation.type == 'evidence' else ('purple' if annotation.type == 'disclosure' else ('yellow' if annotation.type == 'note' else 'orange')) %}
      {% set noteLabel = 'Evidence note' if annotation.type == 'evidence' else ('Disclosure note' if annotation.type == 'disclosure' else ('Note' if annotation.type == 'note' else 'Information request note')) %}
      <div
        class="app-annotation-card js-annotation-card app-annotation-card--{{ tagColour }}"
        data-annotation-id="{{ annotation.id }}"
        {% if annotation.timestampSeconds != null %}data-timestamp-seconds="{{ annotation.timestampSeconds }}"{% endif %}
      >
        <div class="js-annotation-view">
          <p class="app-annotation-card__tag app-annotation-card__tag--{{ tagColour }} govuk-!-margin-bottom-0">
            {{ typeLabel }}
          </p>

          <div class="app-annotation-card__body">
            <div class="app-annotation-card__header">
              <p class="app-annotation-card__name">{{ user.firstName }} {{ user.lastName }}</p>
              <p class="app-annotation-card__time">
                {{ annotation.createdAt | isoDateString | govukDateTime }}
              </p>
            </div>

            {% if annotation.timestampSeconds != null %}
              <dl class="app-annotation-card__elements">
                <dt class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-0">
                  Timestamp
                </dt>
                <dd class="app-annotation-card__note govuk-!-margin-left-0">
                  {{ annotation.selectedText }}
                </dd>
              </dl>
            {% endif %}

            {% if annotation.elements.length %}
              <dl class="app-annotation-card__elements">
                {% for item in annotation.elements %}
                  <dt class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-0">
                    {{ item.element.description }}
                  </dt>
                  <dd class="app-annotation-card__note js-annotation-note govuk-!-margin-left-0">
                    {{ item.reasoning }}
                  </dd>
                {% endfor %}
              </dl>
            {% else %}
              <p class="app-annotation-card__note js-annotation-note">{{ annotation.note }}</p>
            {% endif %}

            {% set isLinkable = (annotation.type == 'evidence' or annotation.type == 'disclosure' or annotation.type == 'note') and not annotation.elements.length and hasElements %}
            {% set editUrl = '/cases/' + caseId + '/review/documents/' + documentId + '/annotations/' + annotation.id + '/edit' %}

            <div class="app-annotation-card__actions govuk-button-group govuk-!-margin-bottom-0">
              <a href="#" class="govuk-link js-change-annotation"{% if isLinkable %} data-edit-target="note"{% endif %}>
                Change
              </a>
              <a
                href="/cases/{{ caseId }}/review/documents/{{ documentId }}/annotations/{{ annotation.id }}/remove?from=document"
                class="govuk-link"
              >
                Remove
              </a>
              {% if isLinkable %}
                {% if annotation.type == 'note' %}
                  <a href="#" class="govuk-link js-change-annotation" data-edit-target="checkboxes">
                    Convert to evidence
                  </a>
                  <a href="#" class="govuk-link js-change-annotation" data-edit-target="checkboxes-disclosure">
                    Convert to disclosure
                  </a>
                {% else %}
                  <a href="#" class="govuk-link js-change-annotation" data-edit-target="checkboxes">
                    Link to {{ 'disclosure' if annotation.type == 'disclosure' else 'evidence' }}
                  </a>
                {% endif %}
              {% endif %}
            </div>
          </div>
        </div>

        <div class="app-annotation-form js-annotation-edit-form" hidden>
          {% if isLinkable %}
            <div class="app-annotation-card--{{ 'purple' if annotation.type == 'disclosure' else 'blue' }} js-annotation-edit-tag-checkboxes" hidden>
              <p class="app-annotation-card__tag app-annotation-card__tag--{{ 'purple' if annotation.type == 'disclosure' else 'blue' }} govuk-!-margin-bottom-0">{{ 'Disclosure' if annotation.type == 'disclosure' else 'Evidence' }}</p>
            </div>
            {% if annotation.type == 'note' %}
              <div class="app-annotation-card--purple js-annotation-edit-tag-checkboxes-disclosure" hidden>
                <p class="app-annotation-card__tag app-annotation-card__tag--purple govuk-!-margin-bottom-0">Disclosure</p>
              </div>
            {% endif %}
            <div class="app-annotation-card--{{ tagColour }} js-annotation-edit-tag-note" hidden>
              <p class="app-annotation-card__tag app-annotation-card__tag--{{ tagColour }} govuk-!-margin-bottom-0">{{ typeLabel }}</p>
            </div>

            <div class="app-annotation-form__body">
              <form method="post" action="{{ editUrl }}" class="js-annotation-edit-checkboxes" hidden>
                <input type="hidden" name="linkAsType" value="{{ 'disclosure' if annotation.type == 'disclosure' else 'evidence' }}" />
                {% for offence in annotation.editOffences %}
                  {% if offence.elementCheckboxItems.length %}
                    {{
                      govukCheckboxes({
                        name: "elementsCheckbox",
                        idPrefix: "element-" + annotation.id + "-charge-" + offence.charge.id,
                        fieldset: {
                          legend: {
                            text: offence.charge.description,
                            isPageHeading: false,
                            classes: "govuk-fieldset__legend--s"
                          }
                        },
                        classes: "govuk-checkboxes--small js-annotation-element-checkboxes",
                        items: offence.elementCheckboxItems
                      })
                    }}
                  {% endif %}
                {% endfor %}

                <div class="govuk-button-group govuk-!-margin-bottom-0">
                  {{
                    govukButton({
                      text: "Save",
                      classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-change-annotation",
                      attributes: { type: "button" }
                    })
                  }}
                  <a href="#" class="govuk-link js-cancel-change-annotation">Cancel</a>
                </div>
              </form>

              {% if annotation.type == 'note' %}
                <form method="post" action="{{ editUrl }}" class="js-annotation-edit-checkboxes-disclosure" hidden>
                  <input type="hidden" name="linkAsType" value="disclosure" />
                  {% for offence in annotation.editDisclosureOffences %}
                    {% if offence.elementCheckboxItems.length %}
                      {{
                        govukCheckboxes({
                          name: "elementsCheckbox",
                          idPrefix: "disclosure-element-" + annotation.id + "-charge-" + offence.charge.id,
                          fieldset: {
                            legend: {
                              text: offence.charge.description,
                              isPageHeading: false,
                              classes: "govuk-fieldset__legend--s"
                            }
                          },
                          classes: "govuk-checkboxes--small js-annotation-element-checkboxes",
                          items: offence.elementCheckboxItems
                        })
                      }}
                    {% endif %}
                  {% endfor %}

                  <div class="govuk-button-group govuk-!-margin-bottom-0">
                    {{
                      govukButton({
                        text: "Save",
                        classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-change-annotation",
                        attributes: { type: "button" }
                      })
                    }}
                    <a href="#" class="govuk-link js-cancel-change-annotation">Cancel</a>
                  </div>
                </form>
              {% endif %}

              <form method="post" action="{{ editUrl }}" class="js-annotation-edit-note">
                {{
                  govukTextarea({
                    name: "note",
                    id: "note-" + annotation.id,
                    value: annotation.note,
                    label: {
                      text: noteLabel,
                      classes: "govuk-label--s"
                    },
                    classes: "govuk-!-margin-bottom-0",
                    rows: 3
                  })
                }}

                <div class="govuk-button-group govuk-!-margin-bottom-0">
                  {{
                    govukButton({
                      text: "Save",
                      classes: "govuk-button--small govuk-!-margin-bottom-0"
                    })
                  }}
                  <a href="#" class="govuk-link js-cancel-change-annotation">Cancel</a>
                </div>
              </form>
            </div>
          {% elif (annotation.type == 'evidence' or annotation.type == 'disclosure') and hasElements %}
            <div class="app-annotation-card--{{ tagColour }}">
              <p class="app-annotation-card__tag app-annotation-card__tag--{{ tagColour }} govuk-!-margin-bottom-0">{{ typeLabel }}</p>
            </div>

            <div class="app-annotation-form__body">
              <form method="post" action="{{ editUrl }}" class="js-annotation-edit-checkboxes">
                {% for offence in annotation.editOffences %}
                  {% if offence.elementCheckboxItems.length %}
                    {{
                      govukCheckboxes({
                        name: "elementsCheckbox",
                        idPrefix: "element-" + annotation.id + "-charge-" + offence.charge.id,
                        fieldset: {
                          legend: {
                            text: offence.charge.description,
                            isPageHeading: false,
                            classes: "govuk-fieldset__legend--s"
                          }
                        },
                        classes: "govuk-checkboxes--small js-annotation-element-checkboxes",
                        items: offence.elementCheckboxItems
                      })
                    }}
                  {% endif %}
                {% endfor %}

                <div class="govuk-button-group govuk-!-margin-bottom-0">
                  {{
                    govukButton({
                      text: "Save",
                      classes: "govuk-button--small govuk-!-margin-bottom-0 js-save-change-annotation",
                      attributes: { type: "button" }
                    })
                  }}
                  <a href="#" class="govuk-link js-cancel-change-annotation">Cancel</a>
                </div>
              </form>
            </div>
          {% else %}
            <div class="app-annotation-card--{{ tagColour }}">
              <p class="app-annotation-card__tag app-annotation-card__tag--{{ tagColour }} govuk-!-margin-bottom-0">{{ typeLabel }}</p>
            </div>

            <div class="app-annotation-form__body">
              <form method="post" action="{{ editUrl }}" class="js-annotation-edit-note">
                {{
                  govukTextarea({
                    name: "note",
                    id: "note-" + annotation.id,
                    value: annotation.note,
                    label: {
                      text: noteLabel,
                      classes: "govuk-label--s"
                    },
                    classes: "govuk-!-margin-bottom-0",
                    rows: 3
                  })
                }}

                <div class="govuk-button-group govuk-!-margin-bottom-0">
                  {{
                    govukButton({
                      text: "Save",
                      classes: "govuk-button--small govuk-!-margin-bottom-0"
                    })
                  }}
                  <a href="#" class="govuk-link js-cancel-change-annotation">Cancel</a>
                </div>
              </form>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}

    {% if not annotations or not annotations.length %}
      <p class="app-annotation-sidebar__empty govuk-body-s js-sidebar-empty"></p>
    {% endif %}
  </div>
</aside>
